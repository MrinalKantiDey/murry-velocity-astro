# =============================================================================
# Velocity - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Variables prefixed with PUBLIC_ are exposed to the browser - NEVER prefix secrets

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Your production site URL (used for sitemap, canonical URLs, OG images)
SITE_URL=https://example.com

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------

# Google Analytics 4 Measurement ID
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager Container ID
PUBLIC_GTM_ID=GTM-K8MNHQJ9


# -----------------------------------------------------------------------------
# Form Handling (optional)
# -----------------------------------------------------------------------------

# External endpoint for contact form submissions
# CONTACT_FORM_ENDPOINT=https://api.example.com/contact

# Where contact form submissions get emailed to (comma-separated for
# multiple owners, requires RESEND_API_KEY below)
# CONTACT_NOTIFICATION_EMAIL=you@example.com,teammate@example.com

# Newsletter service API key (server-side only)
# NEWSLETTER_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# Search Engine Verification (optional)
# -----------------------------------------------------------------------------

# Google Search Console verification code
# GOOGLE_SITE_VERIFICATION=your-verification-code

# Bing Webmaster Tools verification code
# BING_SITE_VERIFICATION=your-verification-code

# -----------------------------------------------------------------------------
# Consent / Privacy (optional)
# -----------------------------------------------------------------------------

# Enable the cookie consent banner (requires analytics to be configured)
# PUBLIC_CONSENT_ENABLED=true

# Link to your privacy policy page (shown in consent banner when set)
# PUBLIC_PRIVACY_POLICY_URL=/privacy

# -----------------------------------------------------------------------------
# E-commerce - Stripe Checkout + Resend fulfillment email (optional)
# -----------------------------------------------------------------------------

# Stripe secret key (test mode: sk_test_..., live mode: sk_live_...)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret - from `stripe listen` locally, or the
# webhook endpoint you create in the Stripe Dashboard for production
# STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API key (resend.com)
# RESEND_API_KEY=re_...

# "From" address for order confirmation emails - must be on a domain
# verified in your Resend account
# RESEND_FROM_EMAIL=orders@murrystreetmedia.com

# Secret used to sign download links - generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOWNLOAD_TOKEN_SECRET=
