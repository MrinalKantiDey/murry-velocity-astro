---
/**
 * About page
 * URL: /about
 */
import { Image } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import CTASection from '@/components/ui/marketing/CTA/CTA.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import founderPortrait from '@/assets/about/founder-portrait.jpeg';
import founderChildhood from '@/assets/about/founder-childhood.jpg';
---

<PageLayout
  title="About Us"
  description="Meet the founder behind Murry Street Media — a story of grit, craft, and a street sign that couldn't make up its mind."
>
  <Hero layout="centered" size="sm" showGrid>
    <Badge slot="badge" pill pulse>Our Story</Badge>

    <h1 slot="title">
      From a mislabeled street sign <span class="text-brand-500">to enterprise media.</span>
    </h1>

    <p slot="description">
      Every great media company needs an origin story. Ours involves a supportive family, a 10-year-old entrepreneur, and a city street sign that couldn't decide how it was spelled.
    </p>
  </Hero>

  {/* ================= Founder intro ================= */}
  <section class="py-[var(--space-section)]">
    <div class="mx-auto grid max-w-5xl items-center gap-10 px-6 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 lg:order-1">
        <Badge pill class="mb-[var(--space-heading-gap)]">Why "Murry"?</Badge>
        <p class="text-lg leading-relaxed text-foreground-secondary">
          Hi, I'm Lacey K. Garner. Long before I was building custom operational workflows or managing multi-million dollar media budgets, I was learning the values of grit, community, and entrepreneurship on the very street that inspired this agency.
        </p>
        <p class="mt-[var(--space-stack-md)] text-lg leading-relaxed text-foreground-secondary">
          One end of my childhood street was spelled Murray, the other Murry. I picked the shorter one and it stuck. The city has since updated the street signs, but I never updated how I spelled my childhood home.
        </p>
        <div class="mt-[var(--space-stack-lg)] border-l-4 border-brand-500 pl-5">
          <p class="font-display text-lg font-bold text-foreground">Lacey K. Garner</p>
          <p class="text-sm text-foreground-muted">Founder & Principal Strategist, Murry Street Media</p>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <div class="overflow-hidden rounded-2xl shadow-xl">
          <Image
            src={founderPortrait}
            alt="Lacey, Founder & Principal Strategist of Murry Street Media"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ================= Origin story ================= */}
  <section class="bg-background-secondary py-[var(--space-section)]">
    <div class="mx-auto grid max-w-5xl items-center gap-10 px-6 lg:grid-cols-2 lg:gap-16">
      <div>
        <div class="overflow-hidden rounded-2xl shadow-xl">
          <Image
            src={founderChildhood}
            alt="Lacey as a child, the ten-year-old entrepreneur behind Murry Street Media's origin story"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
      <div class="space-y-5 text-lg leading-relaxed text-foreground-secondary">
        <Badge pill class="mb-[var(--space-heading-gap)]">The Ten-Year-Old Start-Up</Badge>
        <p>
          While other kids on the block were playing house, I was busy playing business. It was no surprise that I launched my first venture when I was just ten years old.
        </p>
        <p>
          My mom, an arts and crafts fair promoter, gave me a booth space, and my dad jumped into the workshop to help me manufacture our inventory of custom bulletin boards. I skipped the lemonade stand and went straight to a family-backed startup.
        </p>
        <blockquote class="border-l-4 border-brand-500 py-1 pl-6 text-2xl font-bold text-foreground text-balance">
          Launching that first business taught me that if you want to get noticed, you have to build something worth looking at.
        </blockquote>
      </div>
    </div>
  </section>

  {/* ================= Today ================= */}
  <section class="invert-section bg-background py-[var(--space-section)]">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <Badge pill class="mb-[var(--space-heading-gap)]">Where We Are Today</Badge>
      <h2 class="font-display text-2xl font-bold text-balance md:text-3xl">
        With 17 years of experience leading marketing and operations, I founded Murry Street Media to bring absolute transparency, ethical leadership, and high-impact strategy to growing brands.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-on-invert-muted">
        Today, we've traded the craft booths for cutting-edge media strategy and enterprise-level operations, but that same childhood grit, creative spark, and teamwork drives everything we do.
      </p>
      <p class="mx-auto mt-5 max-w-2xl text-lg font-semibold leading-relaxed text-foreground">
        I'm glad you're here, so let's build something efficient together.
      </p>
    </div>
  </section>

  {/* ================= Closing CTA ================= */}
  <CTASection variant="brand" size="lg" maxWidth="md">
    <h2 slot="heading">
      Ready to build something worth looking at?
    </h2>
    <p slot="description">
      Let's map out how to get you noticed.
    </p>
    <Fragment slot="actions">
      <Button size="lg" variant="primary" class="bg-gray-950 text-white hover:bg-gray-800" href={siteConfig.bookingUrl}>
        Schedule Your Alignment Call
      </Button>
      <Button size="lg" variant="outline" class="border-gray-950/20 text-gray-950 hover:bg-gray-950/5" href="/services">
        Explore Our Services
      </Button>
    </Fragment>
  </CTASection>
</PageLayout>
