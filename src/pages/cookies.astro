---
/**
 * Cookie Policy
 * URL: /cookies
 *
 * NOTE: This is placeholder/template copy, not legal advice. Have it
 * reviewed by a lawyer before relying on it in production.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import siteConfig from '@/config/site.config';

const lastUpdated = 'July 20, 2026';
---

<PageLayout title="Cookie Policy" description={`How ${siteConfig.name} uses cookies and similar technologies.`}>
  <section class="mx-auto max-w-3xl px-6 py-[var(--space-section-md)]">
    <h1 class="font-display text-3xl font-bold text-foreground md:text-4xl">Cookie Policy</h1>
    <p class="mt-3 text-sm text-foreground-subtle">Last updated: {lastUpdated}</p>

    <div
      class="prose prose-lg prose-headings:font-display prose-headings:font-bold prose-a:text-brand-600 hover:prose-a:text-brand-500 dark:prose-invert dark:prose-a:text-brand-400 dark:hover:prose-a:text-brand-300 mt-10 max-w-none"
    >
      <p>
        This Cookie Policy explains how {siteConfig.name} uses cookies and similar technologies when
        you visit {siteConfig.url}.
      </p>

      <h2>What Are Cookies?</h2>
      <p>
        Cookies are small text files placed on your device that help websites function properly,
        remember your preferences, and understand how visitors use the site.
      </p>

      <h2>Cookies We Use</h2>
      <ul>
        <li>
          <strong>Essential cookies</strong> — required for core site functionality, such as keeping
          your shopping cart contents as you browse.
        </li>
        <li>
          <strong>Preference cookies</strong> — remember choices like your cookie consent selections
          and light/dark theme.
        </li>
        <li>
          <strong>Analytics cookies</strong> — where enabled, help us understand site traffic and
          usage so we can improve the experience. These only load with your consent.
        </li>
      </ul>

      <h2>Managing Your Preferences</h2>
      <p>
        You can update your cookie preferences at any time using the "Cookie Preferences" link in the
        site footer, or by adjusting your browser settings to block or delete cookies. Note that
        blocking essential cookies may affect how parts of the site function, such as your cart.
      </p>

      <h2>Third-Party Cookies</h2>
      <p>
        Some cookies may be set by third-party services we use, such as analytics or payment
        providers. We don't control these cookies directly — refer to each provider's own policy for
        details.
      </p>

      <h2>Contact Us</h2>
      <p>
        Questions about this policy? Email us at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
      </p>
    </div>
  </section>
</PageLayout>
