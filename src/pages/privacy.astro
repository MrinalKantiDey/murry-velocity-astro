---
/**
 * Privacy Policy
 * URL: /privacy
 *
 * NOTE: This is placeholder/template copy, not legal advice. Have it
 * reviewed by a lawyer before relying on it in production.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import siteConfig from '@/config/site.config';

const lastUpdated = 'July 20, 2026';
---

<PageLayout title="Privacy Policy" description={`How ${siteConfig.name} collects, uses, and protects your information.`}>
  <section class="mx-auto max-w-3xl px-6 py-[var(--space-section-md)]">
    <h1 class="font-display text-3xl font-bold text-foreground md:text-4xl">Privacy Policy</h1>
    <p class="mt-3 text-sm text-foreground-subtle">Last updated: {lastUpdated}</p>

    <div
      class="prose prose-lg prose-headings:font-display prose-headings:font-bold prose-a:text-brand-600 hover:prose-a:text-brand-500 dark:prose-invert dark:prose-a:text-brand-400 dark:hover:prose-a:text-brand-300 mt-10 max-w-none"
    >
      <p>
        {siteConfig.name} ("we," "us," or "our") respects your privacy. This Privacy Policy explains
        what information we collect when you visit {siteConfig.url}, how we use it, and the choices
        you have.
      </p>

      <h2>Information We Collect</h2>
      <p>
        We may collect information you provide directly to us, such as your name, email address,
        and any details you share through our contact form, newsletter signup, or checkout process.
        We also collect limited technical information automatically, such as your browser type, IP
        address, and pages visited, typically through analytics tools.
      </p>

      <h2>How We Use Your Information</h2>
      <ul>
        <li>To respond to your inquiries and provide the services you request.</li>
        <li>To process purchases and deliver digital products you buy from us.</li>
        <li>To send you updates you've opted into, such as our newsletter.</li>
        <li>To understand how visitors use our site, so we can improve it.</li>
      </ul>

      <h2>Cookies</h2>
      <p>
        We use cookies and similar technologies for essential site functionality and, where enabled,
        analytics. See our <a href="/cookies">Cookie Policy</a> for details on what we use and how to
        manage your preferences.
      </p>

      <h2>Third-Party Services</h2>
      <p>
        We may share information with trusted third-party service providers who help us operate our
        business — for example, payment processors, email delivery services, and analytics providers.
        These providers only receive the information necessary to perform their function and are not
        permitted to use it for other purposes.
      </p>

      <h2>Your Rights</h2>
      <p>
        You may request access to, correction of, or deletion of your personal information at any
        time by contacting us using the details below.
      </p>

      <h2>Contact Us</h2>
      <p>
        Questions about this policy? Email us at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
      </p>
    </div>
  </section>
</PageLayout>
