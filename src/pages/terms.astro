---
/**
 * Terms & Conditions
 * URL: /terms
 *
 * NOTE: This is placeholder/template copy, not legal advice. Have it
 * reviewed by a lawyer before relying on it in production.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import siteConfig from '@/config/site.config';

const lastUpdated = 'July 20, 2026';
---

<PageLayout title="Terms & Conditions" description={`The terms that govern your use of ${siteConfig.name}'s website and services.`}>
  <section class="mx-auto max-w-3xl px-6 py-[var(--space-section-md)]">
    <h1 class="font-display text-3xl font-bold text-foreground md:text-4xl">Terms & Conditions</h1>
    <p class="mt-3 text-sm text-foreground-subtle">Last updated: {lastUpdated}</p>

    <div
      class="prose prose-lg prose-headings:font-display prose-headings:font-bold prose-a:text-brand-600 hover:prose-a:text-brand-500 dark:prose-invert dark:prose-a:text-brand-400 dark:hover:prose-a:text-brand-300 mt-10 max-w-none"
    >
      <p>
        These Terms & Conditions ("Terms") govern your use of {siteConfig.url} and any digital
        products or services purchased through it. By using our site or making a purchase, you agree
        to these Terms.
      </p>

      <h2>Digital Products</h2>
      <p>
        Digital products (such as PDF guides) are delivered electronically via a secure download
        link and email attachment upon successful payment. Because these are digital goods delivered
        instantly, all sales are final and non-refundable once the download link has been issued,
        except where required by law.
      </p>

      <h2>Use of Purchased Materials</h2>
      <p>
        When you purchase a digital product from us, you receive a personal, non-transferable license
        to use it for your own business. You may not resell, redistribute, or publicly share the
        files themselves without our written permission.
      </p>

      <h2>Payments</h2>
      <p>
        Payments are processed securely through Stripe. We do not store your full card details on
        our servers.
      </p>

      <h2>Services</h2>
      <p>
        Any paid media, fractional CMO, or consulting services referenced on this site are subject to
        a separate written agreement between {siteConfig.name} and the client, which will govern the
        specific scope, pricing, and terms of that engagement.
      </p>

      <h2>Limitation of Liability</h2>
      <p>
        Our content, products, and services are provided "as is" without warranties of any kind. To
        the fullest extent permitted by law, {siteConfig.name} is not liable for any indirect,
        incidental, or consequential damages arising from your use of our site or products.
      </p>

      <h2>Changes to These Terms</h2>
      <p>
        We may update these Terms from time to time. Continued use of our site after changes are
        posted constitutes acceptance of the revised Terms.
      </p>

      <h2>Contact Us</h2>
      <p>
        Questions about these Terms? Email us at <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
      </p>
    </div>
  </section>
</PageLayout>
